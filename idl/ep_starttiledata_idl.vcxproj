      <Code Type="Fragment" Language="cs">
        <![CDATA[
        foreach (var item in Sources)
        {
            string input = item.ItemSpec;
            string output = item.GetMetadata("OutputFile");

            using (var reader = new StreamReader(input))
            using (var writer = new StreamWriter(output, false, System.Text.Encoding.UTF8))
            {
                bool beginReplaced = false, endReplaced = false;
                string line;
                while ((line = reader.ReadLine()) != null)
                {
                    if (!beginReplaced && line.Contains("// Header files for imported files"))
                    {
                        line = line.Replace("// Header files for imported files", "/*// Header files for imported files");
                        beginReplaced = true;
                    }
                    else if (!endReplaced && line.Contains("#if defined(__cplusplus) && !defined(CINTERFACE)"))
                    {
                        line = line.Replace("#if defined(__cplusplus) && !defined(CINTERFACE)", "*/#if defined(__cplusplus) && !defined(CINTERFACE)");
                        endReplaced = true;
                    }
                    writer.WriteLine(line);
                }
            }
        }

        return true;
        ]]>
      </Code>
